{
  "expo": {
    "name": "Kaizen",
    "slug": "kaizen",
    "scheme": "kaizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      [
        "expo-media-library",
        {
          "musicLibraryPermission": "Allow Kaizen to access your music to import workout tracks."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Kaizen to access your photos to set a profile picture."
        }
      ],
      "expo-notifications"
    ]
  }
}
